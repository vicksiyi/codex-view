{
  "name": "codex-view",
  "version": "0.1.2",
  "description": "Codex CLI 会话可视化面板",
  "license": "MIT",
  "type": "module",
  "bin": {
    "codex-view": "bin/codex-view.js"
  },
  "files": [
    "bin",
    ".next",
    "public",
    "next.config.ts",
    "README.md",
    "LICENSE",
    "!.next/cache",
    "!.next/standalone",
    "!.next/trace",
    "!.next/types"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vicksiyi/codex-view.git"
  },
  "homepage": "https://github.com/vicksiyi/codex-view",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "build:package": "pnpm run build && node scripts/prepare-package.mjs",
    "prepack": "pnpm run build:package",
    "pack:check": "npm pack --dry-run",
    "start": "next start",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "codex",
    "nextjs",
    "sqlite",
    "visualization",
    "cli"
  ],
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.2",
    "lucide-react": "^0.511.0",
    "next": "^16.2.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "swr": "^2.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  }
}
